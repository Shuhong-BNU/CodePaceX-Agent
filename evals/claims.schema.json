{
  "$defs": {
    "Claim": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "description_zh": {
          "title": "Description Zh",
          "type": "string"
        },
        "description_en": {
          "title": "Description En",
          "type": "string"
        },
        "metric_name": {
          "title": "Metric Name",
          "type": "string"
        },
        "aggregation": {
          "description": "Aggregation over measured trials or pairs. p95 uses nearest-rank: sorted_values[ceil(0.95 * n) - 1].",
          "enum": [
            "sum",
            "mean",
            "median",
            "p95",
            "pooled_rate"
          ],
          "title": "Aggregation",
          "type": "string"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "sample_size": {
          "exclusiveMinimum": 0,
          "title": "Sample Size",
          "type": "integer"
        },
        "experiment_conditions": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExperimentConditions"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_run_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Run Ids",
          "type": "array"
        },
        "generated_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated Value"
        },
        "generation_command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generation Command"
        },
        "status": {
          "default": "draft",
          "enum": [
            "draft",
            "verified",
            "insufficient-data"
          ],
          "title": "Status",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "description_zh",
        "description_en",
        "metric_name",
        "aggregation",
        "unit",
        "sample_size"
      ],
      "title": "Claim",
      "type": "object"
    },
    "ExperimentConditions": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "model_id": {
          "title": "Model Id",
          "type": "string"
        },
        "base_url_origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Base Url Origin"
        },
        "git_commit": {
          "title": "Git Commit",
          "type": "string"
        },
        "prompt_version": {
          "title": "Prompt Version",
          "type": "string"
        },
        "model_parameters": {
          "additionalProperties": true,
          "title": "Model Parameters",
          "type": "object"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Timeout Seconds"
        },
        "retry_budget": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Retry Budget"
        },
        "fallback_enabled": {
          "title": "Fallback Enabled",
          "type": "boolean"
        },
        "task_ids": {
          "items": {
            "type": "string"
          },
          "title": "Task Ids",
          "type": "array"
        },
        "repetitions": {
          "minimum": 1,
          "title": "Repetitions",
          "type": "integer"
        },
        "feature_flags": {
          "additionalProperties": true,
          "title": "Feature Flags",
          "type": "object"
        },
        "experiment_profile": {
          "additionalProperties": true,
          "title": "Experiment Profile",
          "type": "object"
        },
        "experiment_profile_hash": {
          "title": "Experiment Profile Hash",
          "type": "string"
        },
        "runtime_contract_hash": {
          "title": "Runtime Contract Hash",
          "type": "string"
        },
        "benchmark_asset_hash": {
          "title": "Benchmark Asset Hash",
          "type": "string"
        },
        "swe_evaluator_architecture": {
          "anyOf": [
            {
              "enum": [
                "native",
                "x86_64"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Swe Evaluator Architecture"
        },
        "max_iterations": {
          "exclusiveMinimum": 0,
          "title": "Max Iterations",
          "type": "integer"
        },
        "pricing_snapshot_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Required provenance for actual_cost_cny Claims only.",
          "title": "Pricing Snapshot Hash"
        },
        "allowed_differences": {
          "description": "Exact registered identity paths allowed to differ; no wildcards.",
          "items": {
            "type": "string"
          },
          "title": "Allowed Differences",
          "type": "array"
        },
        "baseline_run_ids": {
          "items": {
            "type": "string"
          },
          "title": "Baseline Run Ids",
          "type": "array"
        },
        "improved_run_ids": {
          "items": {
            "type": "string"
          },
          "title": "Improved Run Ids",
          "type": "array"
        }
      },
      "required": [
        "provider",
        "protocol",
        "model_id",
        "base_url_origin",
        "git_commit",
        "prompt_version",
        "model_parameters",
        "timeout_seconds",
        "retry_budget",
        "fallback_enabled",
        "task_ids",
        "repetitions",
        "feature_flags",
        "experiment_profile",
        "experiment_profile_hash",
        "runtime_contract_hash",
        "benchmark_asset_hash",
        "max_iterations",
        "allowed_differences"
      ],
      "title": "ExperimentConditions",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 2,
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/Claim"
      },
      "title": "Claims",
      "type": "array"
    }
  },
  "required": [
    "claims"
  ],
  "title": "ClaimDocument",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
